# PostgreSQL — single variable for Next.js, Prisma CLI, seed, and sync.
# Paste the URI from your host (e.g. Neon) dashboard. Password special chars must be percent-encoded in the URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/neondb?sslmode=require"

# Old Postgres (e.g. Supabase) for one-off `npm run db:copy-data-to-neon` — not used by the app.
# DATABASE_URL_SUPABASE="postgresql://..."

# Dev only: if Node/pg fails TLS with "self-signed certificate in certificate chain" (proxy, custom CA),
# or some hosted DBs), set to false. Applies to any host. Do not use in production.
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# When unset in development, the first Prisma use logs redacted DB env + file paths. Set to 0 to silence.
# DATABASE_DEBUG=0

# One-off data copy: old DB → DATABASE_URL (Neon). Apply Prisma migrations on Neon first. Then:
#   npx tsx prisma/copy-data-supabase-to-neon.ts --dry-run
#   CONFIRM_DATA_COPY=yes npx tsx prisma/copy-data-supabase-to-neon.ts
# Or: npm run db:copy-data-to-neon -- --dry-run

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# Used for absolute product image URLs when syncing `Product` rows from products.json (seed / db:sync-products).
AUTH_URL="http://localhost:3000"
# Optional alternative base for image URLs if AUTH_URL is unset.
# NEXT_PUBLIC_APP_URL="https://your-domain.com"

# --- Seed: primary admin (npm run db:seed) — sign in at /login ---
ADMIN_EMAIL="admin@chaesfood.local"
ADMIN_PASSWORD="AdminChaesFood2026!"
SEED_CUSTOMER_EMAIL="customer@chaesfood.local"
SEED_CUSTOMER_PASSWORD="Customer123!"

# Optional: next-auth env demo login (see src/auth.ts). Use same email as ADMIN_EMAIL if you want one account.
DEMO_USER_EMAIL="admin@chaesfood.local"
DEMO_USER_PASSWORD="AdminChaesFood2026!"
# When true, signing in with DEMO_USER_EMAIL + DEMO_USER_PASSWORD always upserts an ADMIN user (handy before seed).
ALLOW_ENV_DEMO_LOGIN="true"

# Optional: pre-fills the login form "Use demo credentials" button (exposed to the browser).
NEXT_PUBLIC_DEMO_LOGIN_EMAIL="admin@chaesfood.local"
NEXT_PUBLIC_DEMO_LOGIN_PASSWORD="AdminChaesFood2026!"

# If `npx prisma migrate deploy` failed once (P3018), clear the failed record then redeploy:
# npx prisma migrate resolve --rolled-back 20260416120000_catalog_orders_redesign

# --- Resend (order confirmation emails) — https://resend.com/docs/dashboard/emails/introduction ---
# RESEND_API_KEY="re_..."
#
# Verified sender only — this exact `from` is used for BOTH emails after checkout (customer confirmation + admin alert).
# RESEND_FROM="Chaes Food <orders@yourdomain.com>"
#
# Real inbox(es) for the admin copy (comma-separated OK). Falls back to ORDER_NOTIFY_EMAIL, then ADMIN_EMAIL.
# ADMIN_RECIPIENT="you@yourdomain.com"
# ORDER_NOTIFY_EMAIL="ops@yourdomain.com"
